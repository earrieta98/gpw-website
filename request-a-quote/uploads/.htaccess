# Prevent execution of any file in this directory
<FilesMatch ".*">
  SetHandler none
  SetHandler default-handler
  Options -ExecCGI
  php_flag engine off
</FilesMatch>

# Deny direct access
<IfModule mod_authz_core.c>
  Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
  Order deny,allow
  Deny from all
</IfModule>
